# ── 数据库 ──────────────────────────────────────────
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=noda_pics
DB_PASS=your-db-password
DB_NAME=noda_pics

# ── Cloudflare R2 存储 ──────────────────────────────
# 在 Cloudflare Dashboard → R2 → Manage R2 API Tokens 创建
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=noda-pics
IMG_BASE=https://img.noda.pics   # 你的 R2 自定义域名
