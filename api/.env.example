# ── 数据库 ──────────────────────────────────────────────────────────────────
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=noda_pics
DB_PASS=your-db-password
DB_NAME=noda_pics

# ── JWT / Session ────────────────────────────────────────────────────────────
SECRET_KEY=change-me-random-string
JWT_SECRET=change-me-another-random-string
# JWT_EXPIRE=43200   # token 有效期（分钟），默认 30 天

# ── 限流 ─────────────────────────────────────────────────────────────────────
RATE_GUEST=3        # 游客每天限额
RATE_USER=10        # 免费用户每天限额
RATE_PRO=100        # Pro 用户每天限额
QUEUE_MAX=20        # 最大排队数

# ── Google OAuth ─────────────────────────────────────────────────────────────
# 在 Google Cloud Console → API & Services → Credentials 创建
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ─────────────────────────────────────────────────────────────
# 在 GitHub → Settings → Developer settings → OAuth Apps 创建
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OAuth 回调域名 ────────────────────────────────────────────────────────────
OAUTH_REDIRECT_BASE=https://your-app.onrender.com

# ── Creem 支付 ────────────────────────────────────────────────────────────────
# 在 https://creem.io Dashboard 获取
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_PRODUCT_PRO=
CREEM_TEST_MODE=true   # 切换到生产时改为 false
