# ── 数据库 ──────────────────────────────────────────────────────────────────
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=noda_pics
DB_PASS=your-db-password
DB_NAME=noda_pics

# ── JWT / Session ────────────────────────────────────────────────────────────
SECRET_KEY=change-me-random-string
JWT_SECRET=change-me-another-random-string
# JWT_EXPIRE=43200   # token 有效期（分钟），默认 30 天

# ── 限流 ─────────────────────────────────────────────────────────────────────
RATE_GUEST=3        # 游客每天限额
RATE_USER=10        # 免费用户每天限额
RATE_PRO=100        # Pro 用户每天限额
QUEUE_MAX=20        # 最大排队数

# ── Google OAuth ─────────────────────────────────────────────────────────────
# 在 Google Cloud Console → API & Services → Credentials 创建
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ─────────────────────────────────────────────────────────────
# 在 GitHub → Settings → Developer settings → OAuth Apps 创建
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OAuth 回调域名 ────────────────────────────────────────────────────────────
OAUTH_REDIRECT_BASE=https://your-app.onrender.com

# ── Creem 支付 ────────────────────────────────────────────────────────────────
# 在 https://creem.io Dashboard 获取
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_PRODUCT_PRO=
CREEM_TEST_MODE=true   # 切换到生产时改为 false

# ── Credits 包（按张计费）─────────────────────────────────────────────────────
# 在 Creem Dashboard 创建 3 个 One-Time 产品，把 product_id 填到这里
# 最新定价：
#   small  $3  / 60  credits → $0.050/张（冲动消费门槛）
#   medium $8  / 250 credits → $0.032/张（甜蜜区）
#   large  $15 / 500 credits → $0.030/张（接近 Pro 单价，引导升级）
CREEM_PRODUCT_CREDITS_SMALL=
CREDITS_SMALL_AMOUNT=60
CREEM_PRODUCT_CREDITS_MEDIUM=
CREDITS_MEDIUM_AMOUNT=250
CREEM_PRODUCT_CREDITS_LARGE=
CREDITS_LARGE_AMOUNT=500

# ── Pro 订阅附送 credits ─────────────────────────────────────────────────────
# Pro = $4.99/月，每月自动充 200 credits（$0.025/张），未用完累积不清零
# 订阅激活 + 每月续费时 webhook 会幂等加（同月不重复）
PRO_MONTHLY_CREDITS=200

# ── Batch（character_pack）上限 ──────────────────────────────────────────────
BATCH_MAX_PROMPTS=20
